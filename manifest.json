{
  "manifest_version": 3,
  "name": "CAI UI",
  "description": "Popup UI for CAI (Cheater AI) with analyzer, snip, and settings.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "CAI",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "Features/selectionIndicator.js",
        "Features/pageAnalyzer.js",
        "Features/pageSnip.js",
        "Features/pageAudio.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
