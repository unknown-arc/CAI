{
  "manifest_version": 3,
  "name": "CAI",
  "description": "CAI with analyzer, snip, and settings.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "CAI",
    "default_popup": "GUI/Popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "Features/SelectionIndicator/main.js",
        "Features/Analyzer/files/extractor.js",
        "Features/Analyzer/main.js",
        "Features/Snip/page/files/state.js",
        "Features/Snip/page/files/helpers.js",
        "Features/Snip/page/files/capture.js",
        "Features/Snip/page/files/context.js",
        "Features/Snip/page/files/lensPanel.js",
        "Features/Snip/page/main.js",
        "Features/Audio/page/files/state.js",
        "Features/Audio/page/files/overlay.js",
        "Features/Audio/page/files/recognition.js",
        "Features/Audio/page/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
